<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.youwin.repository.NoticeRepository">

    <!-- 1. 공지사항 전체 조회 (기존 유지) -->
    <select id="findAll" resultType="com.youwin.dto.NoticeDto">
        SELECT notice_id AS noticeId,
               member_id AS memberId,
               category,
               title,
               content,
               `count`,
               is_pinned AS isPinned,
               create_at AS createAt,
               update_at AS updateAt
        FROM notice_board
        ORDER BY is_pinned DESC, notice_id DESC
    </select>

    <!-- 2. 공지사항 등록 (기존 유지) -->
    <insert id="save" parameterType="com.youwin.dto.NoticeDto">
        INSERT INTO notice_board (
            member_id,
            category,
            title,
            content,
            is_pinned
        ) VALUES (
                     #{memberId},
                     #{category},
                     #{title},
                     #{content},
                     #{isPinned}
                 )
    </insert>

    <!-- 💡 3. [추가] 공지사항 삭제 SQL 쿼리 -->
    <delete id="deleteById" parameterType="long">
        DELETE FROM notice_board
        WHERE notice_id = #{noticeId}
    </delete>

</mapper>