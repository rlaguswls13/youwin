<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.youwin.repository.ChatMessageRepository">

    <select id="findMessages"
            parameterType="int"
            resultType="com.youwin.dto.ChatMessageDto">

        SELECT
            message_id,
            room_id,
            member_id,
            message,
            sent_at
        FROM chat_messages
        WHERE room_id = #{roomId}
        ORDER BY sent_at

    </select>

    <insert id="saveMessage"
            parameterType="com.youwin.dto.ChatMessageDto">

        INSERT INTO chat_messages
        (
            room_id,
            member_id,
            message
        )
        VALUES
            (
                #{roomId},
                #{memberId},
                #{message}
            )

    </insert>

</mapper>